{
  "name": "@mokei/context-server",
  "version": "0.7.0",
  "license": "MIT",
  "homepage": "https://mokei.dev",
  "description": "Mokei MCP server",
  "keywords": [
    "model",
    "context",
    "protocol",
    "mcp",
    "server",
    "llm",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/mokei",
    "directory": "packages/context-server"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build:types:ci": "tsc --emitDeclarationOnly --skipLibCheck --declarationMap false",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@enkaku/node-streams": "catalog:",
    "@sozai/otel": "catalog:",
    "@sozai/schema": "catalog:",
    "@mokei/context-protocol": "workspace:^",
    "@mokei/context-rpc": "workspace:^"
  },
  "devDependencies": {
    "@enkaku/transport": "catalog:",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "catalog:"
  }
}
