{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/typecheck.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "kigu": {
      "source": {
        "source": "github",
        "repo": "TairuFramework/kigu"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "kigu@kigu": true
  }
}
